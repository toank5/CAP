# Sao chép thành .env.development hoặc .env.local rồi chỉnh URL nếu BE đổi port

# Gọi thẳng BE (cần BE bật CORS cho http://localhost:5173)
VITE_API_BASE_URL=https://localhost:7085

# OAuth Web Client ID — cùng giá trị GoogleAuth:ClientId trên BE
VITE_GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com

# Hoặc để trống để dùng proxy Vite (vite.config.ts → localhost:7085), không cần CORS:
# VITE_API_BASE_URL=
